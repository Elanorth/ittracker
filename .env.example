# Flask
SECRET_KEY=buraya-rastgele-uzun-bir-string-yaz
# Oturum çerezi yalnızca HTTPS'te gönderilsin (prod/staging=1). HTTP dev için 0 yap.
SESSION_COOKIE_SECURE=1
# Flask debug modu. Prod/staging'de MUTLAKA 0 — 1 olursa werkzeug interaktif
# debugger'ı (/console) açılır ve uzaktan kod çalıştırmaya yol açar. Yalnızca
# yerel geliştirmede 1 yapın. Prod zaten gunicorn ile çalışır (bkz. Dockerfile).
FLASK_DEBUG=0

# Admin kullanıcı (ilk kurulumda oluşturulur)
ADMIN_USERNAME=levent.can
ADMIN_EMAIL=levent.can@inventist.com
ADMIN_PASSWORD=guclu-bir-sifre-yaz

# Veritabanı
#   Geçiş öncesi (lokal/SQLite):  sqlite:///it_tracker.db
#   Postgres (önerilen, Level 2 — C): postgresql://ittracker:SIFRE@db:5432/ittracker  # pragma: allowlist secret
DATABASE_URL=sqlite:///it_tracker.db

# PostgreSQL — docker-compose'daki `db` servisi için
POSTGRES_DB=ittracker
POSTGRES_USER=ittracker
POSTGRES_PASSWORD=changeme  # pragma: allowlist secret

# Config backup klasörü
BACKUP_DIR=/srv/it_tracker/backups

# SMTP (Office365)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=mail@firma.com
SMTP_PASS=uygulama-sifresi
# v5.25 — Test/staging ortamında GERÇEK mail gönderimini kapat (1 = yalnız logla).
# Staging'de 1 yapın: staging gerçek adreslere ACK/bildirim atıp bounce üretmesin.
MAIL_SUPPRESS=0

# Microsoft 365 OAuth (isteğe bağlı)
O365_CLIENT_ID=
O365_CLIENT_SECRET=
O365_TENANT_ID=common
O365_REDIRECT_URI=http://sunucu-ip:5000/auth/callback

# Glitchtip / Sentry error tracking (opsiyonel — boş bırakılırsa devre dışı)
GLITCHTIP_DSN=
APP_ENV=production
APP_VERSION=v5.0

# Bildirim zamanlaması (v5.10)
# SCHEDULER_TZ: digest saatlerinin yorumlandığı zaman dilimi. Kullanıcılar
#   Ayarlar > Bildirimler'de saati bu dilimde seçer. TR kullanıcıları için önerilen:
SCHEDULER_TZ=Europe/Istanbul
# NOTIFY_HOUR: kişisel saat seçmemiş kullanıcılar için varsayılan digest saati.
NOTIFY_HOUR=9
# NOTIFY_MINUTE: saatlik bildirim job'unun çalıştığı dakika (breach kontrolü her saat).
NOTIFY_MINUTE=0

# SLA iş-saati (v5.13) — destek talebi SLA'sı yalnız çalışma saatleri sayılır.
# SLA_BUSINESS_HOURS=0 ile eski 7/24 davranışa dönülür.
SLA_BUSINESS_HOURS=1
# Çalışma penceresi (yerel saat, SLA_TZ dilimimde). Varsayılan 09:00-18:00.
SLA_WORK_START=9
SLA_WORK_END=18
# Çalışma günleri — Python weekday: Pzt=0 ... Paz=6 (varsayılan Pzt-Cum).
SLA_WORK_DAYS=0,1,2,3,4
# Tatiller — YYYY-MM-DD, virgülle ayrık (o gün SLA saati işlemez). Örn:
# SLA_HOLIDAYS=2026-01-01,2026-04-23,2026-05-01,2026-05-19
SLA_HOLIDAYS=
# SLA saatlerinin yorumlandığı zaman dilimi (belirtilmezse SCHEDULER_TZ, o da yoksa Europe/Istanbul).
SLA_TZ=Europe/Istanbul

# Demo kullanıcılar (demo_*) için password ile login bypass'ı (SADECE STAGING).
# Prod'da BOŞ bırak. =1 ya da =true olursa demo_ prefix'li kullanıcılar O365
# yerine local password ile girebilir (UI testleri için).
ALLOW_DEMO_LOGIN=
