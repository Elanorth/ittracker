# Flask
SECRET_KEY=buraya-rastgele-uzun-bir-string-yaz

# Admin kullanıcı (ilk kurulumda oluşturulur)
ADMIN_USERNAME=levent.can
ADMIN_EMAIL=levent.can@inventist.com
ADMIN_PASSWORD=guclu-bir-sifre-yaz

# Veritabanı (Docker'da sqlite yeterli, PostgreSQL için: postgresql://user:pass@host/db)
DATABASE_URL=sqlite:///it_tracker.db

# Config backup klasörü
BACKUP_DIR=/srv/it_tracker/backups

# SMTP (Office365)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=mail@firma.com
SMTP_PASS=uygulama-sifresi

# Microsoft 365 OAuth (isteğe bağlı)
O365_CLIENT_ID=
O365_CLIENT_SECRET=
O365_TENANT_ID=common
O365_REDIRECT_URI=http://sunucu-ip:5000/auth/callback
