# Flask
SECRET_KEY=buraya-rastgele-uzun-bir-string-yaz

# Admin kullanıcı (ilk kurulumda oluşturulur)
ADMIN_USERNAME=levent.can
ADMIN_EMAIL=levent.can@inventist.com
ADMIN_PASSWORD=guclu-bir-sifre-yaz

# Veritabanı
#   Geçiş öncesi (lokal/SQLite):  sqlite:///it_tracker.db
#   Postgres (önerilen, Level 2 — C): postgresql://ittracker:SIFRE@db:5432/ittracker  # pragma: allowlist secret
DATABASE_URL=sqlite:///it_tracker.db

# PostgreSQL — docker-compose'daki `db` servisi için
POSTGRES_DB=ittracker
POSTGRES_USER=ittracker
POSTGRES_PASSWORD=changeme  # pragma: allowlist secret

# Config backup klasörü
BACKUP_DIR=/srv/it_tracker/backups

# SMTP (Office365)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=mail@firma.com
SMTP_PASS=uygulama-sifresi

# Microsoft 365 OAuth (isteğe bağlı)
O365_CLIENT_ID=
O365_CLIENT_SECRET=
O365_TENANT_ID=common
O365_REDIRECT_URI=http://sunucu-ip:5000/auth/callback

# Glitchtip / Sentry error tracking (opsiyonel — boş bırakılırsa devre dışı)
GLITCHTIP_DSN=
APP_ENV=production
APP_VERSION=v5.0

# Demo kullanıcılar (demo_*) için password ile login bypass'ı (SADECE STAGING).
# Prod'da BOŞ bırak. =1 ya da =true olursa demo_ prefix'li kullanıcılar O365
# yerine local password ile girebilir (UI testleri için).
ALLOW_DEMO_LOGIN=
