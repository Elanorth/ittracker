# IT Tracker v2 — Ortam Değişkenleri
# Bu dosyayı .env olarak kaydedin ve değerleri doldurun

# Flask
SECRET_KEY=gizli-anahtar-buraya-girin
FLASK_ENV=production

# Veritabanı (varsayılan: instance/it_tracker.db)
# DATABASE_URL=sqlite:///it_tracker.db

# SMTP (Mail gönderimi için)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=it@inventist.com
SMTP_PASS=sifreniz

# Microsoft 365 OAuth2 (opsiyonel)
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=

# Config Backup depolama yolu
BACKUP_DIR=C:\it_tracker\backups
