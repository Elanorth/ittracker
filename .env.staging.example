# Staging ortami — prod'dan TAM IZOLE olmali
# Kopya: cp .env.staging.example .env.staging  ve degerleri doldur

# Flask — PROD ile FARKLI olmali (oturum izolasyonu)
SECRET_KEY=staging-icin-ayri-rastgele-string-yaz

# Admin (staging icin ayri sifre)
ADMIN_USERNAME=admin
ADMIN_EMAIL=staging-admin@inventist.com
ADMIN_PASSWORD=staging-icin-guclu-sifre-yaz

# Veritabani — staging.db (prod'a dokunmaz)
DATABASE_URL=sqlite:///staging.db

# Config backup klasoru — prod backup'larindan ayri
BACKUP_DIR=/srv/it_tracker/backups-staging

# SMTP — staging mail gondermesin diye bos birakilabilir
# (gercek SMTP kullanilirsa staging maillerine "[STAGING]" prefix dusunulebilir)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# O365 — staging icin AYRI Azure App Registration onerilir
# Eger ayni app kullanilacaksa Azure'da redirect URI eklenmeli:
#   https://staging.ittracker.inventist.com.tr/auth/callback
O365_CLIENT_ID=
O365_CLIENT_SECRET=
O365_TENANT_ID=common
O365_REDIRECT_URI=https://staging.ittracker.inventist.com.tr/auth/callback

# Cloudflare Tunnel — staging icin AYRI tunnel token
# Cloudflare Zero Trust Dashboard > Networks > Tunnels > Create new tunnel
# Hostname: staging.ittracker.inventist.com.tr -> http://nginx:80
CLOUDFLARE_TUNNEL_TOKEN_STAGING=

# Bildirimler — staging'de scheduler kapali tutulabilir
ENABLE_SCHEDULER=0
